<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <!--     Department Form View-->
    <record id="manage_department_form_view" model="ir.ui.view">
        <field name="name">manage.department.form</field>
        <field name="model">manage.department</field>
        <field name="arch" type="xml">
            <form string="Department" create="true" edit="true">
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="hod_id"/>
                    </group>
                </sheet>
                 <chatter/>
            </form>
        </field>
    </record>

    <!--Department list view-->

    <record id="manage_department_list_view" model="ir.ui.view">
        <field name="name">manage.department.list</field>
        <field name="model">manage.department</field>
        <field name="arch" type="xml">
            <list string="Department">
                <field name="name"/>
                <field name="hod_id"/>
            </list>
        </field>
    </record>


    <!--    Department Action -->

    <record id="action_manage_department" model="ir.actions.act_window">
        <field name="name">Department</field>
        <field name="res_model">manage.department</field>
        <field name="view_mode">list,form</field>
    </record>


</odoo>