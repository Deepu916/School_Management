<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <!--     Class Form View-->
    <record id="manage_class_form_view" model="ir.ui.view">
        <field name="name">manage.class.form</field>
        <field name="model">manage.class</field>
        <field name="arch" type="xml">
            <form string="Class" create="true" edit="true">
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="department_id"/>
                        <field name="head_id"/>
                        <field name="multi_school_id"/>

                    </group>
                </sheet>
                 <chatter/>
            </form>
        </field>
    </record>

    <!--Class list view-->

    <record id="manage_class_list_view" model="ir.ui.view">
        <field name="name">manage.class.list</field>
        <field name="model">manage.class</field>
        <field name="arch" type="xml">
            <list string="Department">
                <field name="name"/>
                <field name="department_id"/>
            </list>
        </field>
    </record>


    <!--    Class Action -->

    <record id="action_manage_class" model="ir.actions.act_window">
        <field name="name">Class</field>
        <field name="res_model">manage.class</field>
        <field name="view_mode">list,form</field>
    </record>


</odoo>