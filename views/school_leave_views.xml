<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <!--    Leave Form View -->
    <record id="school_leaves_view_form" model="ir.ui.view">
        <field name="name">school.leave.form</field>
        <field name="model">school.leave</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <group string="Student Info">
                            <field name="student_id" string="Student"/>
                            <field name="student_class" string="Class"/>
                            <field name="reason" string="Reason"/>
                            <field name="multi_school_id" string="School"/>
                        </group>

                        <group string="Date Info">
                            <field name="half_days" string="Half Day"/>
                            <field name="half_leave" invisible="not half_days" widget="radio"/>
                            <field name="start_date" string="Start Date"/>
                            <field name="end_date" string="End Date"/>
                            <field name="total_days" string="Total Days" invisible="half_days"/>


                        </group>

                    </group>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <!--    Leave List View-->
    <record id="school_leave_list_view" model="ir.ui.view">
        <field name="name">school.leave.list</field>
        <field name="model">school.leave</field>
        <field name="arch" type="xml">
            <list string="Subject">
                <field name="student_id"/>
                <field name="student_class"/>
                <field name="start_date"/>
                <field name="end_date"/>
                <field name="total_days"/>
                <field name="multi_school_id"/>
            </list>
        </field>
    </record>

    <record id="action_school_leave" model="ir.actions.act_window">
        <field name="name">School Leave</field>
        <field name="res_model">school.leave</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>