<?xml version="1.0" encoding="UTF-8" ?>
<odoo>

<!--    Registration Form View-->
     <record id="registration_view_form" model="ir.ui.view">
        <field name="name">registration.form</field>
        <field name="model">school.management.registration</field>
        <field name="arch" type="xml">
            <form string="Registration Form" create="true" edit="true">
                <header>
                    <field name="status" widget="statusbar" readonly="False"/>
                </header>



                <sheet>
                     <field name="sequence"/>
                    <group>
                        <group string="General Info">
                            <field name="f_name"/>
                            <field name="l_name"/>
                            <field name="father"/>
                            <field name="mother"/>
                            <field name="DOB"/>
                            <field name="gender"/>
                            <field name="photo"/>
                            <field name="pre_academic_dpt"/>
                            <field name="pre_class"/>
                            <field name="registration_date"/>
                            <field name="status"/>
                        </group>
                        <group string="contacts Info">
                            <field name="email"/>
                            <field name="phone"/>
                            <field name="tc"/>
                            <field name="adhaar_number"/>
                             <field name="communication_address"/>
                            <field name="same_as_communication"/>
                            <span class="o_form_label o_td_label o_address_type fw-bold" invisible="same_as_communication" >Permanent Address</span>
                            <div class="o_address_format" invisible="same_as_communication">
                                <field name="street" placeholder="Street" class="o_address_street" />
                                <field name="street2" placeholder="Street 2" class="o_address_street"/>
                                <field name="city" placeholder="City" class="o_address_city"/>
                                <field name="state_id" placeholder="State" class="o_address_state" />
                                <field name="zip" placeholder="ZIP" class="o_address_zip"/>
                                <field name="country_id" placeholder="Country" class="o_address_country"/>
                            </div>

                        </group>
                    </group>


                </sheet>
            </form>
        </field>
    </record>


<!--    Registration List View-->
     <record id="registration_view_list" model="ir.ui.view">
        <field name="name">registration.list</field>
        <field name="model">school.management.registration</field>
        <field name="arch" type="xml">

            <list string="Registration">
                 <field name="f_name"/>
                            <field name="l_name"/>
                            <field name="father"/>
                            <field name="mother"/>
                            <field name="email"/>
                            <field name="phone"/>
                            <field name="DOB"/>
                            <field name="gender"/>
<!--                            <field name="photo"/>-->
                            <field name="pre_academic_dpt"/>
                            <field name="pre_class"/>
                            <field name="tc"/>
                            <field name="adhaar_number"/>
                            <field name="status"/>

            </list>
        </field>
    </record>

<!--    Registration Action-->


<record id="action_student_management" model="ir.actions.act_window">
    <field name="name">Registration</field>
    <field name="res_model">school.management.registration</field>
    <field name="view_mode">list,form</field>
</record>




