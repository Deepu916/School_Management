<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <!--     Subject Form View-->
    <record id="manage_subject_form_view" model="ir.ui.view">
        <field name="name">manage.subject.form</field>
        <field name="model">manage.subject</field>
        <field name="arch" type="xml">
            <form string="Subject" create="true" edit="true">
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="department_id"/>

                    </group>
                </sheet>
                 <chatter/>
            </form>
        </field>
    </record>

    <!--Subject list view-->

    <record id="manage_subject_list_view" model="ir.ui.view">
        <field name="name">manage.subject.list</field>
        <field name="model">manage.subject</field>
        <field name="arch" type="xml">
            <list string="Subject">
                <field name="name"/>
                <field name="department_id"/>
            </list>
        </field>
    </record>


    <!--    Subject Action -->

    <record id="action_manage_subject" model="ir.actions.act_window">
        <field name="name">Subject</field>
        <field name="res_model">manage.subject</field>
        <field name="view_mode">list,form</field>
    </record>

</odoo>