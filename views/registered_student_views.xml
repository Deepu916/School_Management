<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <!--    Registered Student Form View -->
    <record id="registered_form_view" model="ir.ui.view">
        <field name="name">registered.student.form</field>
        <field name="model">registered.student</field>
        <field name="arch" type="xml">
            <form string="Registered Student" create="false" >
                <sheet>
                    <group>
                        <group string="General Info">
                        <field name="admission_number" />
                        <field name="f_name"/>
                        <field name="email"/>
                        <field name="club_ids" widget="many2many_tags" />
                    </group>
                    <group string="Academic Info">
                        <field name="current_class_id"/>
                        <field name="attendance" widget="radio"/>
                    </group>
                    </group>
                    <notebook>
                        <page string="Exam">
                            <field name="student_exam_id"/>
                        </page>
                    </notebook>
                </sheet>

            </form>
        </field>
    </record>

    <!--    Registered Student List View -->
    <record id="registered_list_view" model="ir.ui.view">
        <field name="name">registered.student.list</field>
        <field name="model">registered.student</field>
        <field name="arch" type="xml">
            <list create="false" decoration-success="attendance == 'present'"
                  decoration-danger="attendance == 'absent'"
                  decoration-warning="attendance=='half'">
                <field name="f_name"/>
                <field name="admission_number" />
                <field name="email"/>
                <field name="current_class_id"/>
            </list>
        </field>
    </record>

<!--    Registered Student Action-->
     <record id="action_registered_student" model="ir.actions.act_window">
        <field name="name">Registered Student</field>
        <field name="res_model">registered.student</field>
        <field name="view_mode">list,form</field>
         <field name="domain">[('status', '=', 'registered')]</field>
    </record>
</odoo>