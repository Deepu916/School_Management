<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <record id="student_exam_view_form" model="ir.ui.view">
        <field name="name">student.exam.form.view</field>
        <field name="model">student.exam</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <button name="action_add" type="object" string="Assign" class="btn-primary"
                            invisible="state == 'assigned'"/>
                    <field name="state" widget="statusbar"/>
                </header>
                <sheet>
                    <group>
                        <field name="name" string="Exam Name"/>
                        <field name="class_name_id" string="Class"/>
                        <field name="multi_school_id" string="School"/>
                    </group>
                    <notebook>
                        <page string="Papers">
                            <field name="paper_line_ids">
                                <list editable="bottom">
                                    <field name="subject_id" domain="['|', ('department_id', '=', False),('department_id','=',parent.class_department_id)]"/>
                                    <field name="pass_mark"/>
                                    <field name="max_mark"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <!--    Exam List View-->
    <record id="student_exam_list_view" model="ir.ui.view">
        <field name="name">student.exam.list</field>
        <field name="model">student.exam</field>
        <field name="arch" type="xml">
            <list string="Exam">
                <field name="name"/>
                <field name="class_name_id"/>
            </list>
        </field>
    </record>
    <record id="action_student_exam" model="ir.actions.act_window">
        <field name="name">Student Exam</field>
        <field name="res_model">student.exam</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>