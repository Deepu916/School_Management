<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
     <record id="student_club_form_view" model="ir.ui.view">
        <field name="name">student.club.form</field>
        <field name="model">student.club</field>
        <field name="arch" type="xml">
            <form string="Student Club"  >
                <sheet>
                    <div class="oe_button_box" name="button_box">

                        <button type="object"
                                name="action_event_count"
                                class="oe_stat_button"
                                icon="fa-list">

                            <field
                                    name="event_count"
                                   widget="statinfo"
                                   string="Events"/>

                        </button>

                    </div>
                    <group>
                        <field name="name" />
                        <field name="assigner_id" />
                    </group>

                    <notebook>
                        <page string="Student Details">
                            <field name="student_ids" >
                            <list editable="bottom">
                                <field name="f_name"/>
                                <field name="l_name"/>
                                <field name="email"/>
                            </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>


            </form>
        </field>
    </record>

<record id="action_student_club" model="ir.actions.act_window">
        <field name="name">Student Club</field>
        <field name="res_model">student.club</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>