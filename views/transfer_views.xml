<?xml version="1.0" encoding="UTF-8" ?>
<odoo>

    <record id="transfer_form_view" model="ir.ui.view">
        <field name="name">Transfer</field>
        <field name="model">transfer.request</field>
        <field name="arch" type="xml">
            <form string="Department" create="true" edit="true">
                <header>
                    <field name="state" widget="statusbar" readonly="False"/>
                </header>
                <sheet>
                    <group>
                        <field name="student_id"/>
                        <field name="current_company_id"/>
                        <field name="new_company_id"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

      <record id="transfer_list_view" model="ir.ui.view">
        <field name="name">Transfer</field>
        <field name="model">transfer.request</field>
        <field name="arch" type="xml">
            <list string="Transfer Requests"  decoration-danger="state == 'rejected'" decoration-success="state == 'approved'">
                <field name="student_id"/>
                <field name="current_company_id"/>
                <field name="new_company_id" string="New Company"/>
                <button name="action_confirm" string="Approve" type="object" icon="fa-check" invisible="state in ['approved','rejected']" groups="school_management.school_admin_group" />
                <button name="action_reject" string="Reject" type="object" icon="fa-times" invisible="state in ['approved','rejected']" groups="school_management.school_admin_group"/>
            </list>
        </field>
    </record>
    <record id="action_transfer_request" model="ir.actions.act_window">
        <field name="name">Transfer Request</field>
        <field name="res_model">transfer.request</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>