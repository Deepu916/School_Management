<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <data noupdate="1">
        <record id="cron_archive_event" model="ir.cron">
            <field name="name">Archive Past Event</field>
            <field name="model_id" ref="model_club_event"/>
            <field name="state">code</field>
            <field name="code">env['club.event']._event_archive()</field>
            <field name="user_id" ref="base.user_root"/>
            <field name="interval_number">1</field>
            <field name="interval_type">minutes</field>
            <field name="active" eval="True"/>
        </record>
    </data>
</odoo>
