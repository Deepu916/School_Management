<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <data noupdate="1">
        <record id="cron_archive_event" model="ir.cron">
            <field name="name">Archive Past Event</field>
            <field name="model_id" ref="model_club_event"/>
            <field name="state">code</field>
            <field name="code">model._event_archive()</field>
            <field name="user_id" ref="base.user_root"/>
            <field name="interval_number">1</field>
            <field name="interval_type">days</field>
            <field name="active" eval="True"/>
        </record>

        <!--        Scheduled Action For Sending Email To All The Employees-->

        <record id="cron_event_reminder" model="ir.cron">
            <field name="name">Event Reminder</field>
            <field name="model_id" ref="model_club_event"/>
            <field name="state">code</field>
            <field name="code">model.send_event_reminder()</field>
            <field name="user_id" ref="base.user_root"/>
            <field name="interval_number">1</field>
            <field name="interval_type">days</field>
            <field name="active" eval="True"/>
        </record>

        <!--        Schedule Action For Student  Daily Attendance -->
        <record id="cron_daily_attendance" model="ir.cron">
            <field name="name">Student Attendance</field>
            <field name="model_id" ref="model_registered_student"/>
            <field name="state">code</field>
            <field name="code">model.daily_attendance_check()</field>
            <field name="user_id" ref="base.user_root"/>
            <field name="interval_number">1</field>
            <field name="interval_type">days</field>
            <field name="active" eval="True"/>
        </record>
    </data>
</odoo>
