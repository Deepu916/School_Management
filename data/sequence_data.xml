<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <!--    Sequence Number -->
    <data noupdate="1">
        <!--        Unique Register Number -->
        <record id="ir_sequence_student_registration" model="ir.sequence">
            <field name="name">Registration Sequence</field>
            <field name="code">sequence_code</field>
            <field name="prefix">IN-COM-REG-NO-</field>
            <field name="padding">5</field>
            <field name="number_next">1</field>
            <field name="number_increment">1</field>
            <field name="company_id" eval="ref('base.demo_company_in')"/>
        </record>

         <record id="ir_sequence_student_registration_your" model="ir.sequence">
            <field name="name">Registration Sequence</field>
            <field name="code">sequence_code</field>
            <field name="prefix">Your-COM-REG-NO-</field>
            <field name="padding">5</field>
            <field name="number_next">1</field>
            <field name="number_increment">1</field>
            <field name="company_id" eval="ref('base.main_company')"/>
        </record>


        <!--        Unique Admission Number -->
        <record id="student_admission_number_in" model="ir.sequence">
            <field name="name">Student Admission Number </field>
            <field name="code">student_admission</field>
            <field name="prefix">IN-COM-ADM-NO-</field>
            <field name="padding">5</field>
            <field name="number_next">1</field>
            <field name="number_increment">1</field>
            <field name="company_id" eval="ref('base.demo_company_in')"/>
        </record>
        <record id="student_admission_number_your" model="ir.sequence">
            <field name="name">Student Admission Number </field>
            <field name="code">student_admission</field>
            <field name="prefix">YOUR-COM-ADM-NO-</field>
            <field name="padding">5</field>
            <field name="number_next">1</field>
            <field name="number_increment">1</field>
            <field name="company_id" eval="ref('base.main_company')"/>
        </record>

    </data>
</odoo>