<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <data noupdate="1">
        <record id="email_template_remainder" model="mail.template">
            <field name="name">Event Remainder</field>
            <field name="model_id" ref="base.model_res_partner"/>
            <field name="subject">Club Event Reminder</field>
            <field name="email_from">deepuenaswork@gmail.com</field>
            <field name="email_to">{{ object.email }}</field>
            <field name="email_cc"/>
            <field name="body_html" type="html">
                <p>Hi,</p>
                <p>This is a reminder for the upcoming club event/s <t t-out="ctx.get('event_name')"/> in our school</p>
               <p><strong>Please make sure your participation on <t t-out="ctx.get('date_begin')"/></strong></p>
               <br/>
               <p>Best regards,<br/>School Team</p>
            </field>
        </record>
    </data>

</odoo>