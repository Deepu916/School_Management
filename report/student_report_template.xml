<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <template id="student_report_template">
        <t t-call="web.html_container">
            <t t-foreach="docs" t-as="o">
                <t t-call="web.external_layout">
                    <h1 style="text-align:center;">
                        <strong>
                            Student Information
                        </strong>
                    </h1>
                    <div>
                        <strong>Printed Date:</strong>
                        <span t-esc="datetime.date.today()"/>
                    </div>
                    <t t-if="o.class_ids">
                        <t t-set="student_details" t-value="o.class_ids"/>
                    </t>
                    <t t-else="o.department_ids">
                        <t t-set="student_details" t-value="o.department_ids"/>
                    </t>
                    <t t-foreach="student_details" t-as="student_detail">
                        <t t-if="student_detail.student_ids">

                            <div style="page-break-inside: avoid;">
                                 <div class="page">
                                <t t-if="o.class_ids">
                                    <div>
                                       <h5>
                                            <strong>Class:</strong>
                                        <span t-field="student_detail.name"/>
                                       </h5>
                                    </div>
                                    <div>
                                        <h5>
                                            <strong>Department:</strong>
                                        <span t-field="student_detail.department_id.name"/>
                                        </h5>
                                    </div>
                                </t>
                                <t t-elif="o.department_ids">
                                    <div>
                                        <h5>
                                            <strong>Department:</strong>
                                        <span t-field="student_detail.name"/>
                                        </h5>
                                    </div>
                                </t>

                                <br></br>
                            </div>
                            <table class="table table-bordered" style="table-layout: fixed;">
                                <thead>
                                    <tr style="page-break-inside: avoid;">
                                        <th style="padding:12px;">
                                            <strong>SI.NO</strong>
                                        </th>
                                        <th style="padding:12px;">
                                            <strong>Admission Number</strong>
                                        </th>
                                        <th style="padding:12px;">
                                            <strong>Student Name</strong>
                                        </th>
                                        <t t-if="o.department_ids">
                                            <th style="padding:12px;">
                                                <strong>Class</strong>
                                            </th>
                                        </t>
                                        <th style="padding:12px;">
                                            <strong>DOB</strong>
                                        </th>
                                        <th style="padding:12px;">
                                            <strong>Email</strong>
                                        </th>
                                        <th style="padding:12px;">
                                            <strong>Registration Date</strong>
                                        </th>
                                    </tr>
                                </thead>

                                <tbody>
<!--                                    Class Wise Student Details-->
                                    <t t-if="o.class_ids">
                                        <t t-set="students" t-value="student_detail.student_ids"/>
                                        <tr t-foreach="students" t-as="student" style="page-break-inside: avoid;">
                                            <td style="padding:12px;">
                                                <span t-esc="student_index + 1"/>
                                            </td>
                                            <td style="padding:12px;">
                                                <span t-field="student.admission_number"/>
                                            </td>
                                            <td style="padding:12px;">
                                                <span t-field="student.f_name"/>
                                                <span t-field="student.l_name"/>
                                            </td>
                                            <td style="padding:12px;">
                                                <span t-field="student.dob"/>
                                            </td>
                                            <td style="padding:12px;">
                                                <span t-field="student.email"/>
                                            </td>
                                            <td style="padding:12px;">
                                                <span t-field="student.registration_date"/>
                                            </td>
                                        </tr>
                                    </t>
<!--                                    Department Wise Student Details-->
                                    <t t-elif="o.department_ids">
                                        <t t-set="students" t-value="student_detail.student_ids"/>
                                        <tr t-foreach="students" t-as="student" style="page-break-inside: avoid;">
                                            <td style="padding:12px;">
                                                <span t-esc="student_index + 1 "/>
                                            </td>
                                            <td style="padding:12px;">
                                                <span t-field="student.admission_number"/>
                                            </td>
                                            <td style="padding:12px;">
                                                <span t-field="student.f_name"/>
                                                <span t-field="student.l_name"/>
                                            </td>
                                            <td style="padding:12px;">
                                                <span t-field="student.current_class_id.name"/>
                                            </td>
                                            <td style="padding:12px;">
                                                <span t-field="student.dob"/>
                                            </td>
                                            <td style="padding:12px;">
                                                <span t-field="student.email"/>
                                            </td>
                                            <td style="padding:12px;">
                                                <span t-field="student.registration_date"/>
                                            </td>
                                        </tr>
                                    </t>
                                </tbody>
                            </table>
                            </div>
                        </t>
                    </t>
                </t>
            </t>
        </t>
    </template>

</odoo>