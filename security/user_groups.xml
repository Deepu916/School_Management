<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <!--School Management Category -->
    <record id="module_category_school_management" model="ir.module.category">
        <field name="name">School Management</field>
        <field name="sequence">20</field>
    </record>
    <!--    School Management Privilege -->
    <record id="school_management_privilege" model="res.groups.privilege">
        <field name="name">School Access Control</field>
        <field name="category_id" ref="module_category_school_management"/>
    </record>
    <!--    Student Group-->
    <record id="student_group" model="res.groups">
        <field name="name">Student </field>
        <field name="privilege_id" ref="school_management_privilege"/>
    </record>
    <!--Teacher Group-->
    <record id="teacher_group" model="res.groups">
        <field name="name">Teacher </field>
        <field name="privilege_id" ref="school_management_privilege"/>

    </record>

    <!--    Admin Group-->
    <record id="school_admin_group" model="res.groups">
        <field name="name">Administrator</field>
        <field name="privilege_id" ref="school_management_privilege"/>
        <field name="implied_ids" eval="[(4,ref('base.group_system'))]"/>
        <field name="user_ids" eval="[(4, ref('base.user_root')), (4, ref('base.user_admin'))]"/>
    </record>



    <!--Staff Group-->
    <record id="staff_group" model="res.groups">
        <field name="name">Office Staff </field>
        <field name="privilege_id" ref="school_management_privilege"/>
        <field name="implied_ids" eval="[(4,ref('school_admin_group'))]"/>
    </record>

</odoo>
