<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <data noupdate="1">
<!--        Student Leave Details Access -->
        <record id="student_leave_teacher_rule" model="ir.rule">
            <field name="name">Teacher Access on Leave</field>
            <field name="model_id" ref="school_management.model_school_leave"/>
            <field name="groups" eval="[(4,ref('school_management.teacher_group'))]"/>
            <field name="domain_force">[(1,'=',1)]</field>
        </record>

<!--        Exam Details Access-->
        <record id="exam_teacher_rule" model="ir.rule">
            <field name="name">Teacher Access on Exam</field>
            <field name="model_id" ref="school_management.model_student_exam"/>
            <field name="groups" eval="[(4,ref('school_management.teacher_group'))]"/>
            <field name="domain_force">[(1,'=',1)]</field>
        </record>
<!--        Student Registration-->
        <record id="registration_teacher_rule" model="ir.rule">
            <field name="name">Teacher Access on Student Details</field>
            <field name="model_id" ref="school_management.model_school_registration"/>
            <field name="groups" eval="[(4,ref('school_management.teacher_group'))]"/>
            <field name="domain_force">[(1,'=',1)]</field>
        </record>
    </data>
</odoo>